        {
          "name": "size",
          "label": "Size",
          "type": "select",
          "options": [
            "xxlarge",
            "xlarge",
            "large",
            "medium",
            "small",
            "xsmall",
            "xxsmall"
          ]
        },
        {
          "name": "as",
          "label": "As",
          "type": "select",
          "options": [
            "h1",
            "h2",
            "h3",
            "h4",
            "h5",
            "h6",
            "div",
            "span"
          ]
