{
  "components": [
    {
      "name": "Button",
      "importPath": "@atlaskit/button",
      "props": [
        {
          "name": "appearance",
          "label": "Appearance",
          "type": "select",
          "options": [
            "default",
            "danger",
            "link",
            "primary",
            "subtle",
            "subtle-link",
            "warning"
          ]
        },
        {
          "name": "autoFocus",
          "label": "Auto focus",
          "type": "boolean"
        },
        {
          "name": "href",
          "label": "Href",
          "type": "string"
        },
        {
          "name": "isDisabled",
          "label": "Is disabled",
          "type": "boolean"
        },
        {
          "name": "isSelected",
          "label": "Is selected",
          "type": "boolean"
        },
        {
          "name": "spacing",
          "label": "Spacing",
