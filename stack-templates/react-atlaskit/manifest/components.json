        {
          "name": "color",
          "label": "Color",
          "type": "select",
          "options": [
            "color.text",
            "color.text.inverse",
            "color.text.warning.inverse"
          ]
        },
        {
          "name": "testId",
          "label": "Test id",
          "type": "string"
        }
      ],
      "hasChildren": true
    },
    {
      "name": "LoadingButton",
      "importPath": "@atlaskit/button",
      "props": [
        {
          "name": "isLoading",
          "label": "Is loading",
          "type": "boolean"
        }
      ],
      "hasChildren": false
    },
    {
      "name": "Theme",
      "importPath": "@atlaskit/button",
      "props": [
        {
          "name": "isLoading",
          "label": "Is loading",
          "type": "boolean"
        },
        {
          "name": "state",
          "label": "State",
          "type": "select",
          "options": [
            "disabled",
            "default",
            "focusSelected",
            "selected",
            "active",
            "hover",
            "focus"
          ]
        },
        {
          "name": "iconIsOnlyChild",
          "label": "Icon is only child",
          "type": "boolean"
        },
        {
          "name": "mode",
          "label": "Mode",
          "type": "select",
          "options": [
            "light",
            "dark"
          ]
        }
      ],
      "hasChildren": false
    }
