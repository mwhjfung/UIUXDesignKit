          "options": [
            "default",
            "compact",
            "none"
          ]
        },
        {
          "name": "shouldFitContainer",
          "label": "Should fit container",
          "type": "boolean"
        },
        {
          "name": "testId",
          "label": "Test id",
          "type": "string"
        },
        {
          "name": "interactionName",
          "label": "Interaction name",
          "type": "string"
        }
      ],
      "hasChildren": true
    },
    {
      "name": "ButtonGroup",
      "importPath": "@atlaskit/button",
      "props": [
        {
          "name": "testId",
          "label": "Test id",
          "type": "string"
        },
        {
          "name": "label",
          "label": "Label",
          "type": "string"
        },
        {
          "name": "titleId",
          "label": "Title id",
          "type": "string"
        }
      ],
      "hasChildren": true
    },
    {
      "name": "CustomThemeButton",
      "importPath": "@atlaskit/button",
      "props": [
        {
          "name": "isLoading",
          "label": "Is loading",
          "type": "boolean"
        }
      ],
      "hasChildren": false
    },
    {
      "name": "Heading",
      "importPath": "@atlaskit/heading",
