{
  "name": "@pdk/core",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Core library for the Product Design Kit: design-system manifest schema/reader/scaffolder, prototype Vite plugin (markup + tweaker + manifest endpoints), MCP bridge, and the injectable browser toolbar.",
  "files": [
    "dist"
  ],
  "exports": {
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "import": "./dist/manifest/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./requests": {
      "types": "./dist/requests/store.d.ts",
      "import": "./dist/requests/store.js"
    }
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:tools",
    "build:lib": "tsc -p tsconfig.build.json",
    "build:tools": "vite build -c vite.tools.config.ts",
    "test": "vitest run --exclude 'tests/smoke/**'",
    "test:watch": "vitest",
    "test:smoke": "vitest run tests/smoke",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "sass": "^1.83.0",
    "typescript": "~5.8.0",
    "vite": "^7.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vitest": "^3.2.0",
    "vue": "^3.5.25",
    "tsx": "^4.19.0"
  }
}
